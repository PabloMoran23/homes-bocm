{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build-data": "node scripts/build-data.mjs",
    "build-data:public": "BUILD_DATA_SCOPE=madrid-public node scripts/build-data.mjs",
    "prebuild": "node -e \"if(!process.env.SKIP_BUILD_DATA){const e={...process.env};if(e.NEXT_PUBLIC_EDITION==='public'&&!e.BUILD_DATA_SCOPE)e.BUILD_DATA_SCOPE='madrid-public';require('child_process').execSync('npm run build-data',{stdio:'inherit',env:e})}\"",
    "dev": "next dev",
    "dev:public": "NEXT_PUBLIC_EDITION=public next dev",
    "build": "next build",
    "build:public": "NEXT_PUBLIC_EDITION=public BUILD_DATA_SCOPE=madrid-public npm run build",
    "verify:production": "node scripts/verify-production.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "chart.js": "^4.5.1",
    "csv-parse": "^6.2.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "16.2.6",
    "proj4": "^2.20.8",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
